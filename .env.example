# ───── Telegram ─────
# Create a bot via @BotFather to get the token.
# Get your chat_id via @userinfobot (or a group's chat id).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ───── Exchange ─────
# Any ccxt-supported id: binance, bybit, okx, kucoin, ...
EXCHANGE_ID=binance
# future = USDT-M perpetuals, spot = spot
MARKET_TYPE=future

# ───── Scanner ─────
# ccxt symbol format. For perps on Binance use "SYMBOL/USDT:USDT".
WATCHLIST=BTC/USDT:USDT,ETH/USDT:USDT,SOL/USDT:USDT,PYTH/USDT:USDT
TIMEFRAMES=15m,30m,1h,4h
LOOKBACK=300
POLL_INTERVAL=60

# ───── Indicator ─────
ATR_LENGTH=10
ATR_MULT=3.0
RSI_LENGTH=14
RSI_LONG_MIN=50
RSI_SHORT_MAX=50
USE_RSI_FILTER=true
TP_MULTIPLIERS=1,2,3,4
SL_MULTIPLIER=1.5
PRE_SIGNAL_THRESHOLD=0.3
ENABLE_PRE_SIGNAL=true

# ───── State ─────
STATE_FILE=bot_state.json
