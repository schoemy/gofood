# === Konfigurasi Satelit Minebean ===
# Salin file ini ke ".env" lalu isi nilainya.

# Telegram Bot Token — dapat dari @BotFather
TELE_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID (personal atau grup)
TELE_CHAT_ID=your_chat_id_here

# Wallet Anda (lowercase) — dikecualikan dari target lawan
MY_ADDRESS=0x0000000000000000000000000000000000000000

# Interval pemindaian dalam menit
INTERVAL_MENIT=5

# Jumlah ronde terakhir yang ditarik detailnya (max 100)
SCAN_LIMIT=50

# Delay per request (ms) untuk anti-ratelimit. 300–1000ms disarankan.
REQUEST_DELAY_MS=500

# (Opsional) Override base URL API
# BASE_URL=https://api.minebean.com
